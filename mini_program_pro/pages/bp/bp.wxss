page { background-color: #f0f2f5; }
.bp-chart { width: 100%; height: 300rpx; }
.bp-item { display: flex; align-items: center; padding: 24rpx; background: #f8f9fa; border-radius: 20rpx; margin-bottom: 16rpx; }
.bp-icon { width: 72rpx; height: 72rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; font-size: 36rpx; }
.bp-info { flex: 1; }
.bp-title { font-weight: 600; font-size: 28rpx; margin-bottom: 8rpx; display: flex; align-items: center; flex-wrap: wrap; }
.bp-detail { font-size: 22rpx; color: #999; }
.assessment { text-align: center; padding: 40rpx 0; }
.avg-bp { font-size: 64rpx; font-weight: 700; }
.avg-label { color: #999; font-size: 26rpx; margin-top: 8rpx; }
.avg-hr { color: #999; font-size: 24rpx; margin-top: 16rpx; }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: flex-end; justify-content: center; z-index: 100; }
.modal-content { background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 48rpx; width: 100%; max-height: 80vh; overflow-y: auto; }
.modal-title { font-size: 36rpx; font-weight: 600; text-align: center; margin-bottom: 32rpx; }
.form-group { margin-bottom: 32rpx; }
.form-label { font-size: 28rpx; color: #999; margin-bottom: 12rpx; }
.form-input { width: 100%; padding: 24rpx; border: 1rpx solid #e0e0e0; border-radius: 20rpx; font-size: 30rpx; box-sizing: border-box; }
