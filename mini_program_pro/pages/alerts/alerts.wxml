<view class="container">
  <view class="card">
    <view class="card-header">
      <view class="card-title">🔔 预警列表</view>
    </view>
    <view wx:if="{{alertList.length > 0}}">
      <view class="alert-item" wx:for="{{alertList}}" wx:key="id">
        <view class="alert-icon {{item.level === 'critical' ? 'critical' : 'warn'}}">⚠️</view>
        <view class="alert-info">
          <view class="alert-title">{{item.medName}} <text class="tag {{item.tagClass}}">{{item.levelText}}</text></view>
          <view class="alert-time">{{item.time}} · 超时 {{item.diff}} 分钟 · {{item.statusText}}</view>
        </view>
        <button wx:if="{{item.status === 'active'}}" class="btn btn-sm" bindtap="resolveAlert" data-id="{{item.id}}">处理</button>
      </view>
    </view>
    <view wx:else class="empty-state">
      <view class="empty-icon">🔔</view>
      <view class="empty-text">暂无预警</view>
    </view>
  </view>
</view>
