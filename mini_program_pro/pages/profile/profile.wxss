page { background-color: #f0f2f5; }
.container { padding: 24rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06); }
.card-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; }
.avatar-large { width: 160rpx; height: 160rpx; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); margin: 0 auto 32rpx; display: flex; align-items: center; justify-content: center; font-size: 72rpx; color: #fff; }
.profile-name { font-size: 36rpx; font-weight: 600; text-align: center; }
.profile-role { color: #999; font-size: 28rpx; text-align: center; margin-top: 8rpx; }
.about-info { color: #999; font-size: 26rpx; line-height: 2; margin-top: 16rpx; }
.btn { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; border: none; padding: 20rpx 32rpx; border-radius: 20rpx; font-size: 28rpx; font-weight: 600; text-align: center; margin-top: 24rpx; }
.btn-danger { background: linear-gradient(135deg, #ff6b6b, #ee5a52); }
