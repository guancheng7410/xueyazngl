page { background-color: #f0f2f5; }
.container { padding: 24rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.card-title { font-size: 32rpx; font-weight: 600; }
.card-action { color: #667eea; font-size: 26rpx; }
.member-item { display: flex; align-items: center; padding: 24rpx; background: #f8f9fa; border-radius: 20rpx; margin-bottom: 16rpx; }
.member-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; font-size: 28rpx; }
.member-info { flex: 1; }
.member-name { font-weight: 600; font-size: 28rpx; margin-bottom: 8rpx; }
.member-detail { font-size: 22rpx; color: #999; }
.log-item { padding: 16rpx 0; border-bottom: 1rpx solid #eee; }
.log-action { font-weight: 600; font-size: 26rpx; }
.log-detail { color: #999; font-size: 22rpx; }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: flex-end; justify-content: center; z-index: 100; }
.modal-content { background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 48rpx; width: 100%; max-height: 80vh; overflow-y: auto; }
.modal-title { font-size: 36rpx; font-weight: 600; text-align: center; margin-bottom: 32rpx; }
.form-group { margin-bottom: 32rpx; }
.form-label { font-size: 28rpx; color: #999; margin-bottom: 12rpx; }
.form-input { width: 100%; padding: 24rpx; border: 1rpx solid #e0e0e0; border-radius: 20rpx; font-size: 30rpx; box-sizing: border-box; }
.tag { display: inline-block; padding: 6rpx 16rpx; border-radius: 12rpx; font-size: 20rpx; margin-right: 8rpx; }
.tag-blue { background: #e3f2fd; color: #1976d2; }
