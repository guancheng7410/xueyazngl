page {
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #333;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
}

.card-action {
  color: #667eea;
  font-size: 26rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.med-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.med-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
}

.med-icon.blue {
  background: #e3f2fd;
  color: #2196f3;
}

.med-icon.green {
  background: #e8f5e9;
  color: #4caf50;
}

.med-icon.orange {
  background: #fff3e0;
  color: #ff9800;
}

.med-info {
  flex: 1;
}

.med-name {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.med-time {
  font-size: 22rpx;
  color: #999;
}

.btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border: none;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  margin-top: 24rpx;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  margin-top: 0;
}

.btn-danger {
  background: linear-gradient(135deg, #ff6b6b, #ee5a52);
}

.btn-success {
  background: linear-gradient(135deg, #51cf66, #20c997);
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.tag-blue {
  background: #e3f2fd;
  color: #1976d2;
}

.tag-green {
  background: #e8f5e9;
  color: #388e3c;
}

.tag-orange {
  background: #fff3e0;
  color: #f57c00;
}

.tag-red {
  background: #ffebee;
  color: #d32f2f;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
}

.badge {
  background: #ff5757;
  color: #fff;
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  margin-left: 8rpx;
}
